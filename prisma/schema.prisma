// This is your Prisma schema file
// POS SaaS - Multi-Tenant Architecture
// Single Database, Shared Schema with tenantId isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  OWNER
  KASIR
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  TRIAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  HELD
}

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
  CARD
  OTHER
}

enum StockMutationType {
  IN
  OUT
  ADJUSTMENT
  SALE
  RETURN
  PURCHASE // Penerimaan dari purchase order
}

enum PurchaseOrderStatus {
  DRAFT      // Baru dibuat, belum dikirim ke supplier
  ORDERED    // Sudah dipesan ke supplier
  PARTIAL    // Sebagian barang sudah diterima
  RECEIVED   // Semua barang sudah diterima
  CANCELLED  // Dibatalkan
}

enum BillingStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

// ─────────────────────────────────────────────
// PLATFORM CONFIG (dikelola Super Admin)
// ─────────────────────────────────────────────

model PlatformConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  updatedAt DateTime @updatedAt

  @@map("platform_configs")
}

// ─────────────────────────────────────────────
// PRICING PLAN (dikelola Super Admin)
// ─────────────────────────────────────────────

model PricingPlan {
  id           String           @id @default(cuid())
  tier         SubscriptionPlan @unique // FREE, PRO, ENTERPRISE
  name         String           // Display name, misal "Paket Pro"
  description  String?          // Deskripsi singkat
  monthlyPrice Float            @default(0)
  yearlyPrice  Float            @default(0)

  maxProducts  Int @default(50)
  maxCashiers  Int @default(1)
  maxOutlets   Int @default(1)

  features    String[] // List fitur yang ditampilkan di UI
  isActive    Boolean  @default(true) // Bisa dinonaktifkan tanpa hapus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pricing_plans")
}

// ─────────────────────────────────────────────
// TENANT (Badan Usaha / Toko)
// ─────────────────────────────────────────────

model Tenant {
  id          String   @id @default(cuid())
  name        String   // Nama toko
  slug        String   @unique // URL-friendly identifier
  email       String   @unique
  phone       String?
  address     String?
  city        String?
  logoUrl     String?
  currency    String   @default("IDR")
  taxRate     Float    @default(0) // PPN dalam persen, misal 11
  receiptNote String?  // Catatan di bawah struk
  receiptWidth Int     @default(80) // 58 atau 80 mm
  receiptHeader String? // Tagline/slogan di atas struk

  // Konfigurasi invoice
  invoicePrefix String @default("INV") // Prefix nomor invoice

  // Konfigurasi loyalitas
  pointsPerAmount  Int @default(10000) // Rp X belanja = 1 poin
  pointValue       Int @default(100)   // 1 poin = Rp X diskon

  // Metode pembayaran yang aktif (JSON array: ["CASH","QRIS","TRANSFER","CARD"])
  activePaymentMethods String @default("[\"CASH\",\"QRIS\",\"TRANSFER\"]")

  // Subscription
  plan              SubscriptionPlan   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt       DateTime?
  subscriptionEndsAt DateTime?

  // Limits berdasarkan plan
  maxProducts   Int @default(50)   // FREE: 50, PRO: unlimited
  maxCashiers   Int @default(1)    // FREE: 1, PRO: 5, ENTERPRISE: unlimited
  maxOutlets    Int @default(1)    // FREE/PRO: 1, ENTERPRISE: unlimited

  // Downgrade terjadwal — efektif saat subscriptionEndsAt
  scheduledDowngradePlan SubscriptionPlan?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users         User[]
  products      Product[]
  categories    Category[]
  transactions  Transaction[]
  stockMutations StockMutation[]
  billingInvoices BillingInvoice[]
  customers     Customer[]
  outlets       Outlet[]
  cashierShifts CashierShift[]
  stockMutationVariants StockMutationVariant[]
  purchaseOrders PurchaseOrder[]
  auditLogs     AuditLog[]
  notifications AppNotification[]

  @@map("tenants")
}

// ─────────────────────────────────────────────
// OUTLET (Cabang)
// ─────────────────────────────────────────────

model Outlet {
  id        String  @id @default(cuid())
  name      String
  address   String?
  phone     String?
  isMain    Boolean @default(false) // cabang utama, auto-created saat register
  isActive  Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi
  transactions   Transaction[]
  users          User[]
  outletStocks   OutletStock[]
  stockMutations StockMutation[]
  cashierShifts  CashierShift[]
  outletStockVariants OutletStockVariant[]
  stockMutationVariants StockMutationVariant[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@map("outlets")
}

// ─────────────────────────────────────────────
// OUTLET STOCK (stok per cabang)
// ─────────────────────────────────────────────

model OutletStock {
  id       String @id @default(cuid())
  stock    Int    @default(0)
  minStock Int    @default(5)

  outletId  String
  outlet    Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenantId  String // denormalize untuk filter cepat

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, productId])
  @@index([tenantId])
  @@index([productId])
  @@map("outlet_stocks")
}

// ─────────────────────────────────────────────
// USER (Pengguna)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String    // bcrypt hashed
  role          UserRole  @default(KASIR)
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  image         String?

  // PIN offline untuk kasir (di-set oleh Owner)
  offlinePinHash      String?
  offlinePinExpiresAt DateTime?

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outletId String?
  outlet   Outlet? @relation(fields: [outletId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions  Transaction[]
  sessions      Session[]
  accounts      Account[]
  cashierShifts CashierShift[]
  auditLogs     AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────────
// NEXTAUTH TABLES
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// PASSWORD RESET TOKEN
// ─────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// KATEGORI PRODUK
// ─────────────────────────────────────────────

model Category {
  id       String @id @default(cuid())
  name     String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, tenantId])
  @@map("categories")
}

// ─────────────────────────────────────────────
// PRODUK
// ─────────────────────────────────────────────

model Product {
  id          String  @id @default(cuid())
  name        String
  sku         String?
  barcode     String?
  description String?
  imageUrl    String?

  buyPrice  Float @default(0) // Harga beli (base)
  sellPrice Float             // Harga jual (base)

  stock    Int @default(0)
  minStock Int @default(5)  // Threshold low stock alert
  unit     String @default("pcs")

  // Varian produk
  hasVariants Boolean @default(false) // true = stok & harga dikelola per SKU varian

  isActive Boolean @default(true)

  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactionItems TransactionItem[]
  stockMutations   StockMutation[]
  outletStocks     OutletStock[]
  variantTypes     ProductVariantType[]
  variantSKUs      ProductVariantSKU[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([sku, tenantId])
  @@index([tenantId])
  @@index([barcode])
  @@map("products")
}

// ─────────────────────────────────────────────
// VARIAN PRODUK
// ─────────────────────────────────────────────

// Tipe varian: "Ukuran", "Warna", "Rasa", dll
model ProductVariantType {
  id        String  @id @default(cuid())
  name      String  // e.g. "Ukuran", "Warna"
  position  Int     @default(0) // urutan tampil

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  options   ProductVariantOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_variant_types")
}

// Opsi per tipe: "S", "M", "L" atau "Merah", "Biru"
model ProductVariantOption {
  id   String @id @default(cuid())
  name String // e.g. "S", "M", "L"

  variantTypeId String
  variantType   ProductVariantType @relation(fields: [variantTypeId], references: [id], onDelete: Cascade)

  // Relasi ke SKU kombinasi
  skuOptions ProductVariantSKUOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([variantTypeId])
  @@map("product_variant_options")
}

// SKU = kombinasi unik dari semua tipe varian
// Contoh: Kaos S+Merah, Kaos S+Biru, Kaos M+Merah, dst
model ProductVariantSKU {
  id          String  @id @default(cuid())
  sku         String? // SKU spesifik varian ini (auto-generate atau manual)
  barcode     String?
  imageUrl    String? // Gambar opsional per SKU
  price       Float   // Harga jual final (bukan delta, langsung harga penuh)
  buyPrice    Float   @default(0)
  isActive    Boolean @default(true)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Kombinasi opsi yang membentuk SKU ini
  options        ProductVariantSKUOption[]
  outletStocks   OutletStockVariant[]
  stockMutations StockMutationVariant[]
  transactionItems TransactionItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([productId])
  @@map("product_variant_skus")
}

// Junction: SKU ↔ VariantOption (many-to-many)
model ProductVariantSKUOption {
  skuId    String
  sku      ProductVariantSKU    @relation(fields: [skuId], references: [id], onDelete: Cascade)
  optionId String
  option   ProductVariantOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([skuId, optionId])
  @@map("product_variant_sku_options")
}

// Stok per SKU per outlet
model OutletStockVariant {
  id       String @id @default(cuid())
  stock    Int    @default(0)
  minStock Int    @default(5)

  outletId String
  outlet   Outlet            @relation(fields: [outletId], references: [id], onDelete: Cascade)
  skuId    String
  sku      ProductVariantSKU @relation(fields: [skuId], references: [id], onDelete: Cascade)
  tenantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, skuId])
  @@index([tenantId])
  @@index([skuId])
  @@map("outlet_stock_variants")
}

// Mutasi stok per SKU varian
model StockMutationVariant {
  id          String            @id @default(cuid())
  type        StockMutationType
  quantity    Int
  stockBefore Int
  stockAfter  Int
  note        String?

  tenantId String
  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  skuId    String
  sku      ProductVariantSKU @relation(fields: [skuId], references: [id])
  outletId String
  outlet   Outlet            @relation(fields: [outletId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([skuId])
  @@index([outletId])
  @@map("stock_mutation_variants")
}

// ─────────────────────────────────────────────
// PELANGGAN (opsional, untuk loyalty)
// ─────────────────────────────────────────────

model Customer {
  id       String  @id @default(cuid())
  name     String
  phone    String?
  email    String?
  points   Int     @default(0)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, tenantId]) // Satu nomor HP hanya bisa terdaftar sekali per tenant
  @@map("customers")
}

// ─────────────────────────────────────────────
// TRANSAKSI
// ─────────────────────────────────────────────

model Transaction {
  id            String            @id @default(cuid())
  invoiceNumber String            @unique // Nomor struk, misal: INV-20260520-001
  status        TransactionStatus @default(PENDING)
  paymentMethod PaymentMethod     @default(CASH)

  subtotal    Float // Sebelum diskon & pajak
  discount    Float @default(0) // Nominal diskon
  discountPct Float @default(0) // Persen diskon
  tax         Float @default(0) // Nominal pajak
  taxPct      Float @default(0) // Persen pajak
  total       Float // Total akhir = (subtotal - discount) * (1 + taxPct/100)
  amountPaid  Float @default(0) // Uang yang dibayar
  change      Float @default(0) // Kembalian
  pointsEarned   Int @default(0) // Snapshot poin yang diberikan saat transaksi
  pointsRedeemed Int @default(0) // Snapshot poin yang ditukar saat transaksi

  note     String?
  isHeld   Boolean @default(false) // Hold transaction

  tenantId   String
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashierId  String
  cashier    User   @relation(fields: [cashierId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  outletId   String
  outlet     Outlet  @relation(fields: [outletId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items TransactionItem[]

  @@index([tenantId])
  @@index([outletId])
  @@index([createdAt])
  @@map("transactions")
}

model TransactionItem {
  id        String @id @default(cuid())
  quantity  Int
  unitPrice Float  // Harga jual saat transaksi (snapshot)
  buyPrice  Float  @default(0) // Harga beli saat transaksi (snapshot, untuk laba kotor)
  discount  Float  @default(0)
  subtotal  Float  // quantity * unitPrice - discount

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])

  productName  String  // Snapshot nama produk
  productSku   String? // Snapshot SKU

  // Varian (null jika produk tidak punya varian)
  variantSkuId   String?
  variantSku     ProductVariantSKU? @relation(fields: [variantSkuId], references: [id])
  variantLabel   String? // Snapshot label varian, e.g. "M / Merah"

  @@map("transaction_items")
}

// ─────────────────────────────────────────────
// MUTASI STOK
// ─────────────────────────────────────────────

model StockMutation {
  id        String            @id @default(cuid())
  type      StockMutationType
  quantity  Int               // Positif = masuk, negatif = keluar
  stockBefore Int
  stockAfter  Int
  note      String?

  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  outletId  String
  outlet    Outlet  @relation(fields: [outletId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([productId])
  @@index([outletId])
  @@map("stock_mutations")
}

// ─────────────────────────────────────────────
// SHIFT KASIR
// ─────────────────────────────────────────────

enum ShiftStatus {
  OPEN
  CLOSED
}

model CashierShift {
  id          String      @id @default(cuid())
  status      ShiftStatus @default(OPEN)
  openedAt    DateTime    @default(now())
  closedAt    DateTime?
  openingCash Float       @default(0)  // Kas awal
  closingCash Float?                   // Kas akhir (diisi saat tutup)
  note        String?

  // Ringkasan (dihitung saat tutup shift)
  totalTransactions Int   @default(0)
  totalRevenue      Float @default(0)
  totalCash         Float @default(0)
  totalNonCash      Float @default(0)

  cashierId String
  cashier   User   @relation(fields: [cashierId], references: [id])
  outletId  String
  outlet    Outlet @relation(fields: [outletId], references: [id])
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cashierId])
  @@index([tenantId])
  @@index([outletId])
  @@map("cashier_shifts")
}

// ─────────────────────────────────────────────
// BILLING & LANGGANAN (Tripay)
// ─────────────────────────────────────────────

model BillingInvoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  plan            SubscriptionPlan
  amount          Float
  status          BillingStatus @default(PENDING)
  periodStart     DateTime
  periodEnd       DateTime

  // Tripay fields
  tripayReference  String?  @unique // Merchant ref dari Tripay (unique untuk idempotency)
  tripayPaymentUrl String?  // URL pembayaran
  tripayChannel    String?  // Metode pembayaran (BRIVA, MANDIRIVA, dll)
  paidAt           DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("billing_invoices")
}

// ─────────────────────────────────────────────
// PURCHASE ORDER (Pembelian dari Supplier)
// ─────────────────────────────────────────────

model PurchaseOrder {
  id             String              @id @default(cuid())
  poNumber       String              @unique // Nomor PO, e.g. PO-20260523-0001
  status         PurchaseOrderStatus @default(DRAFT)
  supplierName   String?             // Nama supplier (opsional)
  supplierPhone  String?
  note           String?
  expectedDate   DateTime?           // Tanggal estimasi tiba
  receivedAt     DateTime?           // Tanggal diterima

  // Total nilai PO (dihitung dari items)
  totalItems     Int   @default(0)   // Total qty item dipesan
  totalCost      Float @default(0)   // Total harga beli

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outletId String                    // Cabang tujuan penerimaan
  outlet   Outlet @relation(fields: [outletId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PurchaseOrderItem[]

  @@index([tenantId])
  @@index([outletId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  quantity        Int    // Qty dipesan
  quantityReceived Int   @default(0) // Qty sudah diterima
  buyPrice        Float  // Harga beli per unit saat PO dibuat
  note            String?

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])

  // Snapshot nama produk saat PO dibuat
  productName String
  productSku  String?

  // Varian SKU (opsional — diisi jika produk punya varian)
  variantSkuId String?
  variantSku   ProductVariantSKU? @relation(fields: [variantSkuId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// ─────────────────────────────────────────────
// AUDIT LOG (jejak aktivitas pengguna)
// ─────────────────────────────────────────────

model AuditLog {
  id         String  @id @default(cuid())
  action     String  // e.g. "CREATE", "UPDATE", "DELETE"
  entity     String  // e.g. "Product", "Category", "Staff", "Settings"
  entityId   String? // ID record yang terpengaruh
  entityName String? // Snapshot nama (e.g. nama produk saat dihapus)
  changes    Json?   // { before: {...}, after: {...} } — hanya field yang berubah

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// NOTIFIKASI IN-APP
// ─────────────────────────────────────────────

enum NotificationType {
  LOW_STOCK       // Stok produk menipis / habis
  NEW_TRANSACTION // Transaksi baru selesai
  SYSTEM          // Pesan sistem (trial, billing, dll)
}

model AppNotification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?          // URL tujuan saat notifikasi diklik

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tenantId, isRead])
  @@index([tenantId, createdAt])
  @@map("app_notifications")
}
